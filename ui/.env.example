# Example OpenAI-compatible provider settings
# Copy this file to .env and replace the values with your own credentials.
# If you do not create ui/.env, the app runs in mock mode automatically.
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=kimi-k2.5

# Optional: force mock mode even if credentials are present
# NEXT_PUBLIC_USE_MOCK=true
